{
  "manifest_version": 3,
  "name": "YouTube Dislike Preview",
  "version": "1.0.2",
  "description": "See likes & dislikes on every YouTube thumbnail — instantly, no clicking required.",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://returnyoutubedislikeapi.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Youtube Dislike Preview",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}